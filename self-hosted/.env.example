# VibeCheck Self-Hosted Configuration

# Working directory for Claude Code (default: current directory)
WORK_DIR=.

# Web UI settings
WEB_PORT=8501
WEB_HOST=0.0.0.0

# Language: "en" or "ko" (default: "en")
BOT_LANG=en

# Slack integration (optional - leave empty to disable)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
